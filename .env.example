# Copy these into `.env.local` for local development.
#
# Visitor analytics dashboard + MongoDB persistence
#
# Atlas "bad auth" / code 8000 almost always means the username/password in the URI
# are wrong OR the password contains reserved URL characters (@ : / ? # [ ]) and must
# be percent-encoded. Use Atlas "Connect → Drivers" URI and reset the DB user
# password if unsure. Username is the Atlas database user name, not your Atlas login email.
#
# Optional: if auth still fails, try forcing a mechanism (pick one):
# MONGODB_AUTH_MECHANISM=SCRAM-SHA-256
# MONGODB_AUTH_MECHANISM=SCRAM-SHA-1
MONGODB_URI=mongodb+srv://REPLACE_ME
ADMIN_PASSWORD=your_secure_password_here
